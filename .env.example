# Get a free API key at https://aistudio.google.com → "Get API key"
# Single key:
GEMINI_API_KEY=

# Or, for automatic fallback when a free-tier key gets rate-limited,
# supply several comma-separated keys — the app rotates to the next one
# whenever the current key returns a 429/quota error:
# GEMINI_API_KEYS=key1,key2,key3

# Optional: override the model (defaults to gemini-flash-latest)
# GEMINI_MODEL=gemini-flash-latest
